<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/mycreation2">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <ImageView
                android:id="@+id/ivRegisterLogo"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/chat_logo"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#DAE5ED"
                app:cardElevation="16dp"
                app:cardCornerRadius="50dp"
                android:layout_margin="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16sp"
                        android:fontFamily="@font/alata"
                        android:gravity="center"
                        android:letterSpacing="0.05"
                        android:text="Register Here :"
                        android:textColor="#0E7C40"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etRegisterName"
                        android:layout_width="match_parent"
                        android:layout_height="40sp"
                        android:layout_margin="15sp"
                        android:layout_marginTop="12sp"
                        android:background="@drawable/et_bg_shape"
                        android:drawableLeft="@drawable/icon_black_person"
                        android:drawablePadding="7sp"
                        android:fontFamily="@font/aoboshi_one"
                        android:gravity="center_vertical"
                        android:hint="Name"
                        android:paddingLeft="4sp"
                        android:textColor="@color/black"
                        android:textColorHint="#666666"
                        android:textSize="16sp"
                        android:textStyle="normal" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="#070707" />

                    <EditText
                        android:id="@+id/etRegisterMobileNumber"
                        android:layout_width="match_parent"
                        android:layout_height="40sp"
                        android:drawableLeft="@drawable/icon_calls"
                        android:gravity="center_vertical"
                        android:layout_margin="15sp"
                        android:drawablePadding="7sp"
                        android:layout_marginTop="12sp"
                        android:background="@drawable/et_bg_shape"
                        android:fontFamily="@font/aoboshi_one"
                        android:hint="Mobile"
                        android:paddingLeft="4sp"
                        android:textColor="@color/black"
                        android:textColorHint="#666666"
                        android:textSize="16sp"
                        android:textStyle="normal" />

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#070707"
                        android:layout_marginHorizontal="10dp"/>

                    <EditText
                        android:id="@+id/etRegisterEmailId"
                        android:layout_width="match_parent"
                        android:layout_height="40sp"
                        android:layout_margin="15sp"
                        android:drawableLeft="@drawable/icon_email"
                        android:drawablePadding="7sp"
                        android:layout_marginTop="12sp"
                        android:background="@drawable/et_bg_shape"
                        android:fontFamily="@font/aoboshi_one"
                        android:gravity="center_vertical"
                        android:hint="Email"
                        android:paddingLeft="4sp"
                        android:textColor="@color/black"
                        android:textColorHint="#666666"
                        android:textSize="16sp"
                        android:textStyle="normal" />

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#070707"
                        android:layout_marginHorizontal="10dp"/>

                    <EditText
                        android:id="@+id/etRegisterUsername"
                        android:layout_width="match_parent"
                        android:layout_height="40sp"
                        android:layout_margin="15sp"
                        android:drawablePadding="5sp"
                        android:drawableLeft="@drawable/icon_black_person"
                        android:layout_marginTop="12sp"
                        android:background="@drawable/et_bg_shape"
                        android:fontFamily="@font/aoboshi_one"
                        android:hint="Username"
                        android:gravity="center_vertical"
                        android:paddingLeft="4sp"
                        android:textColor="@color/black"
                        android:textColorHint="#666666"
                        android:textSize="16sp"
                        android:textStyle="normal" />

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#070707"
                        android:layout_marginHorizontal="10dp"/>

                    <EditText
                        android:id="@+id/etRegisterPassword"
                        android:layout_width="match_parent"
                        android:layout_height="40sp"
                        android:layout_margin="15sp"
                        android:drawableLeft="@drawable/outline_lock_24"
                        android:drawablePadding="7sp"
                        android:layout_marginTop="12sp"
                        android:background="@drawable/et_bg_shape"
                        android:fontFamily="@font/aoboshi_one"
                        android:hint="Password"
                        android:gravity="center_vertical"
                        android:paddingLeft="7sp"
                        android:textColor="@color/black"
                        android:textColorHint="#666666"
                        android:textSize="16sp"
                        android:textStyle="normal" />

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#070707"
                        android:layout_marginHorizontal="10dp"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnRegister"
                        android:layout_width="130dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:layout_margin="16sp"
                        android:layout_marginTop="16sp"
                        android:background="@drawable/btn_shape"
                        android:fontFamily="serif"
                        android:gravity="center"
                        android:letterSpacing="0.03"
                        android:text="Register"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
